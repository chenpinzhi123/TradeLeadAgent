# ============ 搜索 Query 构建 ============

def _build_search_queries(
    product: str,
    target_market: str,
    buyer_type: str = "importer",
) -> List[str]:
    """
    构建多维度搜索query，覆盖不同搜索意图。
    核心目标：找到真实公司网站、联系方式，而非平台、论坛、新闻。
    策略：
      1. 产品别名扩展（同义词/近义词）
      2. 使用 -site: 排除大平台
      3. 使用 filetype:html 或 site:.com/.de 等限定公司官网
      4. 多语言query（按目标市场语言）
      5. 海关数据、展会、行业协会等高意向来源
    """
    market_suffix = getattr(config, "MARKET_KEYWORDS", {}).get(target_market, target_market)

    # 产品关键词扩展：英文别名 + 行业关键词
    product_keywords = _expand_product_keywords(product)
    
    # 构建排除平台的大段表达式（用于query）
    exclude_expr = " -alibaba -1688 -made-in-china -globalsources -tradekey -ec21 -exportpages -diytrade -b2b168 -dhgate -amazon -ebay -aliexpress -walmart -target -costco -bestbuy -tmall -jd -taobao -youtube -facebook -instagram -twitter -tiktok -reddit -quora -pinterest -weibo -douyin -wikipedia -wordpress -medium -blogspot -ghost -indeed -glassdoor -monster -51job -zhaopin -craigslist -kijiji -linkedin -baike -zhihu -sohu -sina -163 -ifeng -csdn -oschina -gov.cn -edu.cn"
    
    queries = []
    
    # 对每个产品关键词变体生成query（限制3个变体，避免query过多）
    for pkw in product_keywords[:3]:
        queries.extend([
            # 核心：直接找进口商/分销商，带contact/email，排除平台
            f'"{pkw}" {buyer_type} {market_suffix} "contact" "email" {exclude_expr}',
            f'"{pkw}" distributor {market_suffix} wholesale {exclude_expr}',
            f'"{pkw}" import company {market_suffix} "looking for supplier" {exclude_expr}',
            f'"{pkw}" procurement {market_suffix} -retail -amazon {exclude_expr}',
            
            # 公司官网类：直接找 .com/.de/.fr 等域名下的公司页面
            f'"{pkw}" {market_suffix} company "import" OR "distribute" "email" {exclude_expr}',
            f'"{pkw}" {market_suffix} "buyer" OR "purchasing" -blog -news {exclude_expr}',
            
            # 高价值B2B来源（site:限定）
            f'site:kompass.com "{pkw}" {market_suffix}',
            f'site:europages.com "{pkw}" {market_suffix}',
            f'site:thomasnet.com "{pkw}" {market_suffix}',
            f'site:go4worldbusiness.com "{pkw}" {market_suffix}',
            f'site:tradeindia.com "{pkw}" {market_suffix}',
            
            # 海关数据 / 展会 exhibitor（高价值）
            f'"{pkw}" {market_suffix} "customs data" importer OR "bill of lading" {exclude_expr}',
            f'"{pkw}" {market_suffix} trade show exhibitor "contact" {exclude_expr}',
            f'"{pkw}" {market_suffix} "exporter" OR "supplier" directory {exclude_expr}',
            
            # 行业协会/商会
            f'"{pkw}" {market_suffix} "association" OR "chamber of commerce" member {exclude_expr}',
            f'"{pkw}" {market_suffix} industry association member list {exclude_expr}',
            
            # 公司官网：限定常见顶级域名（提高找到真实公司官网的概率）
            f'"{pkw}" {market_suffix} importer site:.com OR site:.de OR site:.fr OR site:.uk OR site:.it OR site:.es OR site:.nl OR site:.pl OR site:.au OR site:.ca',
            f'"{pkw}" {market_suffix} distributor site:.com OR site:.de OR site:.fr OR site:.uk OR site:.it OR site:.es OR site:.nl OR site:.pl OR site:.au OR site:.ca',
        ])

    # 按目标市场语言生成本地query
    queries.extend(_build_localized_queries(product, target_market, market_suffix))
    
    # 去重
    seen = set()
    unique_queries = []
    for q in queries:
        if q not in seen:
            seen.add(q)
            unique_queries.append(q)
    
    # 限制query数量，避免搜索太慢（最多30个）
    return unique_queries[:30]


def _expand_product_keywords(product: str) -> List[str]:
    """扩展产品关键词：英文别名 + 同义词"""
    keywords = [product]
    
    # 常见产品类别的扩展词（可继续补充）
    expansions = {
        "clothing": ["apparel", "garment", "fashion", "wear"],
        "electronics": ["electronic device", "consumer electronics", "electronic products"],
        "furniture": ["home furniture", "office furniture", "furnishing"],
        "textile": ["fabric", "cloth", "textile products"],
        "machinery": ["machine", "equipment", "industrial machinery"],
        "food": ["food products", "beverage", "edible"],
        "cosmetic": ["beauty products", "skincare", "makeup"],
        "toy": ["toys", "games", "playthings"],
        "jewelry": ["jewellery", "accessories", "ornaments"],
        "led": ["LED lighting", "LED light", "LED lamp"],
        "bag": ["bags", "luggage", "handbag", "backpack"],
        "shoe": ["shoes", "footwear", "sneakers"],
        "gift": ["gifts", "promotional items", "souvenirs"],
        "home": ["household", "home products", "houseware"],
        "kitchen": ["kitchenware", "cooking utensils", "kitchen tools"],
        "sports": ["sporting goods", "fitness equipment", "outdoor gear"],
        "auto": ["automotive", "car parts", "vehicle accessories"],
        "medical": ["medical equipment", "healthcare products", "medical supplies"],
        "packaging": ["packaging materials", "packing", "package"],
        "plastic": ["plastic products", "plastic goods", "injection molding"],
        "metal": ["metal products", "metal parts", "sheet metal"],
        "glass": ["glass products", "glassware", "crystal"],
        "ceramic": ["ceramics", "pottery", "porcelain"],
        "wood": ["wooden products", "woodwork", "timber"],
        "chemical": ["chemicals", "chemical products", "industrial chemicals"],
        "agriculture": ["agricultural products", "farm products", "agro"],
    }
    
    p_lower = product.lower()
    for key, synonyms in expansions.items():
        if key in p_lower:
            for syn in synonyms:
                if syn not in keywords:
                    keywords.append(syn)
    
    # 如果 product 是中文，保留原词并添加英文
