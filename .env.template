# ============ LLM 配置 ============
# 可选值: openai / anthropic / none
LLM_PROVIDER=none

# LLM API Key（留空则使用模板模式，无需API Key）
LLM_API_KEY=

# 模型名称（openai: gpt-4o-mini / gpt-4o；anthropic: claude-3-5-sonnet-latest）
LLM_MODEL=gpt-4o-mini

# 自定义LLM endpoint（可选，用于兼容OpenAI接口的第三方服务）
LLM_BASE_URL=

# ============ 搜索配置 ============
MAX_SEARCH_RESULTS=20
SEARCH_TIMEOUT=15

# ============ 爬取配置 ============
SCRAPE_TIMEOUT=10
MAX_PAGES_PER_LEAD=3
